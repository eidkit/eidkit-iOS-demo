# Copy this file to local.yml (gitignored) and set your Apple Developer Team ID.
# Find it at: https://developer.apple.com/account -> Membership -> Team ID
targets:
  EidKitApp:
    settings:
      base:
        DEVELOPMENT_TEAM: YOUR_TEAM_ID

# Optional: override the remote SDK with a local checkout for development.
# This lets you edit the SDK and test from Xcode without going through a release.
#
# Add the following to your local.yml, then run `xcodegen generate`:
#
# packages:
#   EidKit:
#     path: ../eidkit-ios
#
# To revert back to the released version, remove the packages override from
# local.yml and run `xcodegen generate` again.
